# Stripe secret key (Dashboard → Developers → API keys). Use sk_test_... for development.
STRIPE_SECRET_KEY=
# Price ID for £14.99/month (Dashboard → Products → Add product → Recurring £14.99/month, copy Price ID)
STRIPE_PRICE_ID=
# Webhook signing secret (Dashboard → Developers → Webhooks → Add endpoint → select events, copy signing secret). Required for production.
STRIPE_WEBHOOK_SECRET=
PORT=4242

