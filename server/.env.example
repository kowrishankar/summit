# Stripe secret key (Dashboard → Developers → API keys). Use sk_test_... for dev, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_key_here
# Recurring price IDs (Dashboard → Products → Pricing — copy price_...). If unset, falls back to STRIPE_PRICE_ID.
# Personal £4.99 / Business £9.99 / Practice £14.99 per month (match your Stripe products).
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_PRICE_ID_INDIVIDUAL=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_PRACTICE=
# Trial length (days) when users choose “Start with free trial” — tier defaults: 7 / 14 / 30
# If set, applies to any tier that does not have its own env below (legacy single value).
# STRIPE_TRIAL_PERIOD_DAYS=60
STRIPE_TRIAL_DAYS_INDIVIDUAL=7
STRIPE_TRIAL_DAYS_BUSINESS=14
STRIPE_TRIAL_DAYS_PRACTICE=30
# Webhook signing secret (Dashboard → Developers → Webhooks → Add endpoint → copy signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PORT=4242

# Required for POST /close-account (delete user + Stripe customer). Dashboard → Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

