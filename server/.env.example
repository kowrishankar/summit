# Stripe secret key (Dashboard → Developers → API keys). Use sk_test_... for dev, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_key_here
# Price ID for £4.99/month (Dashboard → Products → your product → Pricing, copy Price ID)
STRIPE_PRICE_ID=price_your_price_id_here
# Free trial length (days) when users choose “Start with free trial” — charge runs automatically after trial
STRIPE_TRIAL_PERIOD_DAYS=60
# Webhook signing secret (Dashboard → Developers → Webhooks → Add endpoint → copy signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PORT=4242

# Required for POST /close-account (delete user + Stripe customer). Dashboard → Settings → API.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

