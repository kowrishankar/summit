# Optional: for automatic invoice extraction from images/PDFs
# Get your key from https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=

# Stripe (required for subscription). Get keys from https://dashboard.stripe.com/apikeys
# Use pk_test_... and sk_test_... for development.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Backend URL for Stripe (server folder). Use http://localhost:4242 for simulator; use your machine IP for physical device (e.g. http://192.168.1.5:4242).
EXPO_PUBLIC_STRIPE_API_URL=http://192.168.4.25:4242
STRIPE_PRICE_ID=prod_...
STRIPE_SECRET_KEY=sk_test_...