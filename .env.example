# Supabase (required for auth and data – central backend). Create project at https://supabase.com
# In Dashboard: Settings → API. Use the publishable key (client-safe); legacy "anon" key also works.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional: for automatic invoice extraction from images/PDFs
# Get your key from https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=

# Stripe (required for subscription). Get keys from https://dashboard.stripe.com/apikeys
# CRITICAL: Use Test mode keys together (pk_test_ + sk_test_) OR Live together (pk_live_ + sk_live_).
# Mismatch causes "No such setupintent" when adding a card. Same Stripe account for both.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Backend URL for Stripe (server folder). Use http://localhost:4242 for simulator; use your machine IP for physical device (e.g. http://192.168.1.5:4242).
EXPO_PUBLIC_STRIPE_API_URL=http://localhost:4242
# Server-only (never in the Expo app): must match publishable key mode (test vs live).
STRIPE_SECRET_KEY=sk_test_...
# Price ID from Dashboard → Products → price_... (not prod_...)
STRIPE_PRICE_ID=price_...
# Optional: match server STRIPE_TRIAL_PERIOD_DAYS so signup/subscribe copy shows the correct number of days (default 14)
# EXPO_PUBLIC_STRIPE_TRIAL_DAYS=14